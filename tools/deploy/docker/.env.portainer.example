# =============================================================================
# Environment variables for the production Portainer stack
# (tools/deploy/docker/docker-compose.portainer.yml)
# =============================================================================
# In Portainer, paste these into the Stack's "Environment variables" section
# rather than committing a filled-in .env file. Never commit real secrets.
#
# Legend:  [REQUIRED] must be set   |   others have safe defaults
# =============================================================================

# --- image -------------------------------------------------------------------
# Released image tag published to ghcr.io/tturnerdev/litestar-fullstack.
# Pin to a real release (e.g. v0.3.0). Avoid "latest" in production.
APP_IMAGE_TAG=latest

# --- application -------------------------------------------------------------
# [REQUIRED] Long random string. Generate with: openssl rand -hex 32
# Rotating this invalidates all existing sessions / tokens.
SECRET_KEY=
# [REQUIRED] Public base URL the app is served from (through your proxy).
APP_URL=https://app.example.com
# Comma-separated list, or a JSON array. Set to your real origin(s).
ALLOWED_CORS_ORIGINS=["https://app.example.com"]
# Reverse-proxy trust. "*" trusts all X-Forwarded-* headers; if the app port
# is reachable from untrusted networks, set this to your proxy's IP/CIDR.
LITESTAR_TRUSTED_PROXIES=*
# Send cookies only over HTTPS (your proxy terminates TLS).
COOKIE_SECURE=true
# Python stdlib log level number: 10=DEBUG 20=INFO 30=WARNING.
LOG_LEVEL=20
# Host port the app container publishes (your reverse proxy connects here).
APP_PORT=8000

# --- database (PostgreSQL) ---------------------------------------------------
POSTGRES_VERSION=17
POSTGRES_USER=app
POSTGRES_DB=app
# [REQUIRED] Strong password for the application database user.
POSTGRES_PASSWORD=
DATABASE_POOL_SIZE=10
DATABASE_MAX_POOL_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=300
DATABASE_PRE_POOL_PING=true

# --- cache / background queue (Valkey) ---------------------------------------
VALKEY_VERSION=8
SAQ_PROCESSES=1
SAQ_CONCURRENCY=10

# --- email -------------------------------------------------------------------
# EMAIL_BACKEND: console (logs only, default) | smtp | resend
EMAIL_BACKEND=console
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Litestar App
# When EMAIL_BACKEND=smtp:
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_USE_TLS=true
# When EMAIL_BACKEND=resend:
RESEND_API_KEY=

# --- OAuth (optional) --------------------------------------------------------
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GITHUB_OAUTH2_CLIENT_ID=
GITHUB_OAUTH2_CLIENT_SECRET=

# --- initial admin (first deploy only) ---------------------------------------
# Set these on the first deploy to create the initial superuser. The init
# service is idempotent — it skips creation if the user already exists.
# You can remove these after the first successful deploy.
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=
INIT_ADMIN_NAME=Admin

# --- resource limits ---------------------------------------------------------
APP_CPU_LIMIT=2
APP_MEM_LIMIT=1g
WORKER_CPU_LIMIT=1
WORKER_MEM_LIMIT=1g

# --- automated database backups ----------------------------------------------
PG_BACKUP_VERSION=17
# Cron expression or @daily / @hourly / @weekly.
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# --- object storage (rustfs, S3-compatible) ----------------------------------
RUSTFS_VERSION=latest
# [REQUIRED] Credentials for the rustfs server; the app uses the same pair as
# its AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
# Bucket used for uploads (created automatically by the storage-init job).
STORAGE_BUCKET=uploads
# Host port for the rustfs web console — only if you uncomment the `ports`
# block on the `storage` service (put it behind your reverse proxy).
# STORAGE_CONSOLE_PORT=9001
