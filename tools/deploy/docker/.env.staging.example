# =============================================================================
# Staging Environment Configuration
# =============================================================================
# Copy this file and configure it in your Portainer stack environment variables,
# or save it as .env.staging alongside the docker-compose.staging.yml file.
#
# Required variables are marked with [REQUIRED].
# All others have sensible defaults for a staging environment.
# =============================================================================

# [REQUIRED] GitHub repository in owner/repo format (used for image pull)
# Example: your-org/admin-portal
GITHUB_REPO=

# [REQUIRED] Application secret key (generate with: openssl rand -hex 32)
SECRET_KEY=

# Database credentials
# These configure both the Postgres container and the app connection string.
DATABASE_USER=app
DATABASE_PASSWORD=app
DATABASE_DB=app

# Application
APP_PORT=8000
APP_URL=http://localhost:8000
LOG_LEVEL=20

# Email
# Staging uses Mailpit by default. The SMTP host/port are hardcoded in the
# compose file to point at the mailpit container. These control the From header.
EMAIL_ENABLED=true
EMAIL_FROM_ADDRESS=noreply@staging.local
EMAIL_FROM_NAME=Admin Portal (Staging)

# Mailpit web UI port (view captured emails)
MAILPIT_PORT=8025

# Worker
SAQ_PROCESSES=1
SAQ_CONCURRENCY=10

# OAuth (optional — leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Sentry (optional — leave disabled for staging unless needed)
SENTRY_ENABLED=false
SENTRY_DSN=
